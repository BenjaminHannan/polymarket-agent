# Paper-trading config. Copy to .env to override defaults.
STARTING_NAV=10000
MAX_MARKETS=50
MIN_LIQUIDITY=5000
ARB_THRESHOLD=0.99
PER_TRADE_SIZE=100
MAX_PER_MARKET=500

# News-driven paper trader
ENABLE_NEWS_TRADER=1
NEWS_TRADE_PER_TRADE_NOTIONAL=25
NEWS_TRADE_MAX_PER_MARKET=75
NEWS_TRADE_MAX_DAILY=500
NEWS_TRADE_MIN_OVERLAP=3
NEWS_TRADE_MIN_CONFIDENCE=0.4
NEWS_TRADE_MIN_SCORE=0.20
NEWS_TRADE_MAX_ASK=0.85
NEWS_TRADE_COOLDOWN_SEC=300

# Statistical layer (LightGBM)
ENABLE_STAT_SIGNAL=1
LGBM_MODEL_PATH=
STAT_POLL_SEC=120
STAT_MIN_EDGE=0.10

# Optional: Chronos-Bolt zero-shot forecaster (~150MB HF download on first load)
ENABLE_CHRONOS=0

# Free API keys (paste your own)
ALCHEMY_RPC_URL=
FRED_API_KEY=
BLS_API_KEY=
CONGRESS_API_KEY=
COURTLISTENER_API_KEY=
SEC_EDGAR_USER_AGENT=Your Name your.email@example.com
BLUESKY_APP_PASSWORD=
